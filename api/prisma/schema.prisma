model Customer {
  id String @id @default(uuid()) @db.Uuid
  name String
  balance BigInt
  phoneNumber String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([name])
  @@index([balance])
  @@index([createdAt])
  // money type
  // foreight keys .....

  @@map("customer")
}
