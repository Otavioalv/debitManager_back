// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



// Período de aplicação dos juros: diário, mensal, anual
enum InterestPeriod {
  DAILY       // Juros aplicados diariamente
  MONTHLY     // Juros aplicados mensalmente
  ANNUALLY    // Juros aplicados anualmente
}

// Status do contrato: ativo, finalizado, cancelado, inadimplente
enum ContractStatus { 
  ACTIVE      // Contrato ativo, em andamento
  FINISHED    // Contrato finalizado, todas as parcelas pagas
  CANCELED    // Contrato cancelado, não mais válido
  DEFAULTED   // Contrato inadimplente, com parcelas vencidas e não pagas
}

// Frequência de vencimento das parcelas: diária, semanal, quinzenal, mensal, anual
enum InstallmentFrequency {
  DAILY         // Vencimentos diários
  WEEKLY        // Vencimentos semanais
  BIWEEKLY      // Vencimentos quinzenais
  MONTHLY       // Vencimentos mensais
  ANNUALLY      // Vencimentos anuais

  /* 
    DAILY
    WEEKLY
    BIWEEKLY
    MONTHLY
    BIMONTHLY
    QUARTERLY
    SEMIANNUALLY
    ANNUALLY
   */
}


// Status da parcela: pendente, parcial, paga, vencida
enum InstallmentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}


// Metodos de pagamentos
enum PaymentMethod {
  PIX
  CASH
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
}


model Person {
  id String @id @default(uuid()) @db.Uuid
  name String

  // balance String @default("0")

  phoneNumber String
  secondaryPhoneNumber String?

  cpf String?
  cnpj String?

  rg String?
  cnh String?

  stateRegistration String?
  municipalRegistration String?

  contracts Contract[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Filters
  @@index([name])
  @@index([createdAt])
  
  
  // @@unique([name, id])
  // @@unique([balance, id])
  
  @@map("person")
}


model Contract {
  id String @id @default(uuid()) @db.Uuid

  title String
  description String?

  personId String @db.Uuid
  person Person @relation(fields: [personId], references: [id], onDelete: Restrict)

  
  totalAmount String          // Valor total do contrato
  installmentCount Int        // Quantidade de parcelas
  installmentFrequency InstallmentFrequency   // Intervalo entre vencimentos
  interestRate Decimal @db.Decimal(6,2)       // Juros em porcentagem

  timezone String                         // Timezone do contrato criado
  interestPeriod InterestPeriod           // Período de aplicação dos juros (diário, mensal, etc.)
  // startDate DateTime @db.Date             // Data de início do contrato
  // startDateUtc DateTime @db.Timestamptz   // Data exata
  startAt DateTime @db.Timestamptz           // Data de inicio do contrato

  // Configurações para pular sábados, domingos e feriados
  skipSaturday Boolean @default(false)    
  skipSunday Boolean @default(false)
  // skipHoliday Boolean @default(false)

  status ContractStatus @default(ACTIVE)    // Status do contrato (ativo, finalizado, cancelado)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

  // Relação com as parcelas do contrato
  installments Installment[]

  // Índices para otimizar consultas
  @@index([personId])
  @@index([startAt])
  @@index([status])

  @@map("contract") // Mapeia a tabela para "contract" no banco de dados
}

model Installment {
  id String @id @default(uuid()) @db.Uuid
  contractId String @db.Uuid

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  installmentNumber Int                          // Número da parcela (1, 2, 3, ...)
  originalAmount String               // Valor original da parcela
  // interestAmount String              // Valor monetario dos juros do contrato sobre a parcela
  remainingAmount String              // Valor restante a ser pago  

  accruedInterest String @default("0")      // Juros acumulados até o momento

  dueAt DateTime @db.Timestamptz                      // Data de inicio vencimento da parcela      
  paidAt DateTime? @db.Timestamptz                    // Data de pagamento da parcela (null se não paga)

  status InstallmentStatus @default(PENDING)      // Status da parcela (pendente, parcial, paga, vencida)

  createdAt DateTime @default(now())              // Data de criação da parcela
  updatedAt DateTime @updatedAt                   // Data de última atualização da parcela

  payments Payment[]    // Pode ter varios Payments

  // Índices para otimizar consultas
  @@unique([contractId, installmentNumber])
  @@index([contractId])
  @@index([dueAt])
  @@index([status])

  @@map("installment")
}


model Payment {
  id String @id @default(uuid()) @db.Uuid
  installmentId String @db.Uuid

  installment Installment @relation(fields: [installmentId], references: [id])

  amount String

  interestAmount String @default("0")
  method PaymentMethod

  paidAt DateTime @db.Timestamptz @default(now())
  
  createdAt DateTime @db.Timestamptz @default(now())
  // Possivel opção data de update (se for necessario atualizar o pagamento)

  @@index([installmentId])
  @@index([paidAt])
  
  @@map("payment")
}

