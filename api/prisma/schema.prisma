// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



// Período de aplicação dos juros: diário, mensal, anual
enum InterestPeriod {
  DAILY       // Juros aplicados diariamente
  MONTHLY     // Juros aplicados mensalmente
  ANNUALLY    // Juros aplicados anualmente
}

// Status do contrato: ativo, finalizado, cancelado, inadimplente
enum ContractStatus { 
  ACTIVE      // Contrato ativo, em andamento
  FINISHED    // Contrato finalizado, todas as parcelas pagas
  CANCELED    // Contrato cancelado, não mais válido
  DEFAULTED   // Contrato inadimplente, com parcelas vencidas e não pagas
}

// Frequência de vencimento das parcelas: diária, semanal, quinzenal, mensal, anual
enum InstallmentFrequency {
  DAILY         // Vencimentos diários
  WEEKLY        // Vencimentos semanais
  BIWEEKLY      // Vencimentos quinzenais
  MONTHLY       // Vencimentos mensais
  ANNUALLY      // Vencimentos anuais
}




model Customer {
  id String @id @default(uuid()) @db.Uuid
  name String
  balance BigInt
  phoneNumber String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  contracts Contract[]

  // Filters
  @@index([name])
  @@index([balance])
  @@index([createdAt])
  
  
  // @@unique([name, id])
  // @@unique([balance, id])
  // money type
  // foreight keys .....
  
  @@map("customer")
}


model Contract {
  id String @id @default(uuid()) @db.Uuid

  title String
  description String?

  customerId String @db.Uuid
  customer Customer @relation(fields: [customerId], references: [id])
  
  totalAmount BigInt          // Valor total do contrato
  installmentCount Int        // Quantidade de parcelas
  installmentFrequency InstallmentFrequency   // Intervalo entre vencimentos
  interestRate Decimal @db.Decimal(6,2)       // Juros em porcentagem

  interestPeriod InterestPeriod           // Período de aplicação dos juros (diário, mensal, etc.)
  startDate DateTime                      // Data de início do contrato

  // Configurações para pular sábados, domingos e feriados
  skipSaturday Boolean @default(false)    
  skipSunday Boolean @default(false)
  // skipHoliday Boolean @default(false)

  status ContractStatus @default(ACTIVE)    // Status do contrato (ativo, finalizado, cancelado)

  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt

  // Relação com as parcelas do contrato
  // installments Installment[]

  // Índices para otimizar consultas
  @@index([customerId])
  @@index([startDate])
  @@index([status])

  @@map("contract") // Mapeia a tabela para "contract" no banco de dados
}
