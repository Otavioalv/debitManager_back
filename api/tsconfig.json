{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,

    "ignoreDeprecations": "6.0",

    
    "sourceMap": true,
    "types": ["vitest/globals", "node"],


    // "noUncheckedSideEffectImports": true,

    // "moduleDetection": "force",
    "paths": {
      "@/*": ["./src/*"],
      "@generated/*": ["./generated/*"]
    }
  }
}

